{
  "mcpServers": {
    "stitch": {
      "command": "node",
      "args": [
        "D:/absolute/path/to/codex-stitch-frontend-kit/server/stitch-proxy.mjs"
      ],
      "env": {
        "GOOGLE_CLOUD_PROJECT": "replace-with-your-google-cloud-project-id",
        "HTTP_PROXY": "http://127.0.0.1:7897",
        "HTTPS_PROXY": "http://127.0.0.1:7897"
      }
    }
  }
}
